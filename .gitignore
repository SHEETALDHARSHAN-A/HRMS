# Monorepo-wide ignore rules

# Environment and secret files
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Node and frontend build output
node_modules/
**/node_modules/
dist/
build/
*.tsbuildinfo

# Logs and runtime dumps
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE/editor and OS files
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Misc
*.local
tmp/
*.sqlite3
