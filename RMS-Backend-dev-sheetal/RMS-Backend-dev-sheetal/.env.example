# Environment Configuration File
# Copy this file to .env and fill in your actual values

# Core Configuration
ENVIRONMENT=development
PORT=8000

# URL Configuration
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
API_PREFIX=/api

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
TEMPERATURE=0.7
OPENAI_CACHE=true

# PostgreSQL Configuration
DB_NAME=rms_database
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_POOL_SIZE=10
DB_MAX_OVER_FLOW=20

# Auth & Security Configuration
OTP_EXPIRE_SECONDS=300
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ACCESS_REFRESH_TOKEN_EXPIRE_HOURS=24
REMEMBER_ME_EXPIRE_DAYS=7

# SMTP Configuration (REQUIRED FOR EMAIL OTP)
# For Gmail, use: smtp.gmail.com:587
# For Outlook/Hotmail, use: smtp-mail.outlook.com:587
# For Yahoo, use: smtp.mail.yahoo.com:587
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# CORS Configuration
SAMESITE=lax
SECURE=false
ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
ALLOW_DOMAINS=["localhost","127.0.0.1"]

# Invitation Configuration
INVITE_EXPIRE_MINUTES=60
INVITE_EXPIRE_SECONDS=3600

# Other Configuration
REPORT_MAIL=admin@yourcompany.com
DEFAULT_TENANT_ID=default
LINK_EXPIRATION=3600
INTERNAL_SERVICE_TOKEN=your_internal_service_token

# Gmail SMTP Setup Instructions:
# 1. Enable 2-factor authentication on your Gmail account
# 2. Generate an App Password:
#    - Go to Google Account settings
#    - Security > 2-Step Verification > App passwords
#    - Generate a new app password for "Mail"
#    - Use this app password as SMTP_PASSWORD (not your regular Gmail password)
# 3. Set SMTP_USERNAME to your full Gmail address

# For other email providers:
# - Ensure you have the correct SMTP server and port
# - Some providers require app-specific passwords or OAuth
# - Check your email provider's documentation for SMTP settings